# ─── Required ────────────────────────────────────────────────────────────────
# Your Trading212 API key (generate in-app: Settings → API)
T212_API_KEY=your_api_key_here

# ─── Safety ──────────────────────────────────────────────────────────────────
# Set to true to simulate all orders without sending them (recommended for testing)
PAPER_MODE=true

# Hard cap per single order in account currency (GBP/EUR/USD)
MAX_ORDER_VALUE=100

# Master kill-switch — set to false to disable all order placement
TRADING_ENABLED=true

# ─── Storage ─────────────────────────────────────────────────────────────────
# Path to SQLite trade log database
DB_PATH=/data/trades.db

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
